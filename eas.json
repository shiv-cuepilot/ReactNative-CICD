{
  "cli": {
    "version": ">= 16.32.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "distribution": "store",
      "channel": "development",
      "autoIncrement": true,
      "android": {
        "gradleCommand": ":app:bundleDevelopmentRelease"
      },
      "ios": {
        "scheme": "development"
      }
    },
    "staging": {
      "distribution": "store",
      "channel": "staging",
      "autoIncrement": true,
      "android": {
        "gradleCommand": ":app:bundleStagingRelease"
      },
      "ios": {
        "scheme": "staging"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "gradleCommand": ":app:bundleProductionRelease"
      },
      "ios": {
        "scheme": "production"
      }
    }
  },
  "submit": {
    "development": {
      "android": {
        "track": "internal"
      },
      "ios": {
        "bundleIdentifier": "com.snapbiodata.app.development"
      }
    },
    "staging": {
      "android": {
        "track": "alpha"
      },
      "ios": {
        "bundleIdentifier": "com.snapbiodata.app.staging"
      }
    },
    "production": {
      "android": {
        "track": "production"
      },
      "ios": {
        "bundleIdentifier": "com.snapbiodata.app"
      }
    }
  }
}
